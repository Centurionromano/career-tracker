rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // CIRUGÍA DE SEGURIDAD: Eliminamos el temporizador de 30 días.
      // Ahora, SOLO los usuarios con una sesión iniciada pueden acceder a la base de datos.
      // (Como tu frontend ya filtra por userId, esto blinda el proyecto perfectamente).
      allow read, write: if request.auth != null;
    }
  }
}